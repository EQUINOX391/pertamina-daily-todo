# Frontend
VITE_API_BASE_URL=http://localhost:5190/api

# Backend
ASPNETCORE_ENVIRONMENT=Development

# ASP.NET Core configuration keys
# Use double underscore (__) for nested configuration when using environment variables.
Jwt__Key=replace-with-secure-development-secret-at-least-32-characters
Jwt__Issuer=PertaminaDailyTodo.Api
Jwt__Audience=PertaminaDailyTodo.Frontend
Jwt__ExpiresInMinutes=60
ConnectionStrings__DefaultConnection=Server=(localdb)\MSSQLLocalDB;Database=PertaminaDailyTodoDb;Trusted_Connection=True;TrustServerCertificate=True;
